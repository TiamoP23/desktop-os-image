[org/gnome/shell]
disable-user-extensions=false
enabled-extensions=['dash-to-panel@jderose9.github.com', 'blur-my-shell@aunetx', 'clipboard-indicator@tudmotu.com']
favorite-apps=['org.gnome.Nautilus.desktop', 'firefox.desktop', 'org.gnome.Software.desktop', 'org.gnome.Console.desktop']

[org/gnome/desktop/interface]
clock-format='24h'
clock-show-weekday=true
color-scheme='prefer-dark'
enable-hot-corners=false

[org/gnome/desktop/peripherals/touchpad]
tap-to-click=true

[org/gnome/desktop/wm/preferences]
button-layout='appmenu:minimize,maximize,close'
num-workspaces=1

[org/gnome/mutter]
center-new-windows=true
workspaces-only-on-primary=false


[org/gnome/shell/extensions/clipboard-indicator]
toggle-menu=['<Super>v']

