{
	"name": "Ubuntu",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
	"mounts": [
		"source=${localEnv:XDG_RUNTIME_DIR}/podman/podman.sock,target=/var/run/podman/podman.sock,type=bind"
	],
	"containerEnv": {
		"CONTAINER_HOST": "unix:///var/run/podman/podman.sock",
		"DOCKER_HOST": "unix:///var/run/podman/podman.sock"
	},
	"features": {
		"./bluebuild": {},
		"./podman": {}
	}
}
